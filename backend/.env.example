# Application
ENV=development
APP_NAME=submission-service
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=submission_user
POSTGRES_PASSWORD=submission_pass
POSTGRES_DB=submission_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# AWS (LocalStack em dev, IAM Role em produção)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Em produção: remova esta linha — o SDK usa o endpoint real da AWS automaticamente
AWS_ENDPOINT_URL=http://localhost:4566

# SQS
SQS_QUEUE_NAME=submissions-corrections
SQS_DLQ_NAME=submissions-corrections-dlq
SQS_QUEUE_URL=http://localhost:4566/000000000000/submissions-corrections
SQS_DLQ_URL=http://localhost:4566/000000000000/submissions-corrections-dlq
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME_SECONDS=5
SQS_VISIBILITY_TIMEOUT=60

# S3 (Storage de texto das submissões)
S3_BUCKET=submissions-texts


# Worker
WORKER_POLL_INTERVAL_MS=500
WORKER_MAX_RETRIES=3
